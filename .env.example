# ─────────────────────────────────────────
# SEO Data Provider (pick one)
# ─────────────────────────────────────────
# Options: dataforseo | semrush | ahrefs
SEO_PROVIDER=dataforseo

# DataForSEO
DATAFORSEO_USERNAME=
DATAFORSEO_PASSWORD=

# SEMrush (https://www.semrush.com/api-analytics/)
SEMRUSH_API_KEY=

# Ahrefs (https://ahrefs.com/api/v3)
AHREFS_API_TOKEN=

# ─────────────────────────────────────────
# AI Provider
# ─────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────
# Slack Bot Integration
# ─────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=seo-reports
CHAT_API_URL=http://localhost:3000/api/chat

# ─────────────────────────────────────────
# Web Scraper
# ─────────────────────────────────────────
GOOGLE_GEMINI_KEY=

# ─────────────────────────────────────────
# Discord Bot Integration
# (https://discord.com/developers/applications → New Application → Bot)
# ─────────────────────────────────────────
DISCORD_BOT_TOKEN=

# ─────────────────────────────────────────
# Telegram Bot Integration
# (Talk to @BotFather on Telegram → /newbot)
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─────────────────────────────────────────
# Microsoft Teams (Bot Framework)
# (https://portal.azure.com → Azure Bot resource)
# TEAMS_APP_TYPE: MultiTenant | SingleTenant | UserAssignedMSI
# ─────────────────────────────────────────
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_APP_TYPE=MultiTenant
TEAMS_APP_TENANT_ID=

# ─────────────────────────────────────────
# WhatsApp via Twilio
# (https://www.twilio.com/console/sms/whatsapp/sandbox)
# Set BOT_PUBLIC_URL so PDF download links in WhatsApp replies resolve.
# Without TWILIO_AUTH_TOKEN, inbound requests are unsigned (dev only).
# ─────────────────────────────────────────
TWILIO_AUTH_TOKEN=
BOT_PUBLIC_URL=

# ─────────────────────────────────────────
# Email reply (SMTP outbound)
# Inbound mail: point a SendGrid Inbound Parse / Mailgun Route at
# POST {BOT_PUBLIC_URL}/api/webhook/email
# ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─────────────────────────────────────────
# Interactive CLI (local testing)
# ─────────────────────────────────────────
BOT_CLI_ENABLED=

# ─────────────────────────────────────────
# Bot server (hosts Teams + generic webhook + web widget + admin)
# ─────────────────────────────────────────
BOT_SERVER_PORT=4000

# Comma-separated API keys. When set, /api/message and /api/activity
# require one of these keys via Authorization: Bearer / X-API-Key / ?api_key.
BOT_API_KEYS=

# Sliding-window rate limit (per key or per IP).
BOT_RATE_LIMIT_MAX=30
BOT_RATE_LIMIT_WINDOW_SEC=60

# Activity log: ring size + optional JSONL file for persistence.
BOT_ACTIVITY_RING=200
BOT_ACTIVITY_FILE=

# ─────────────────────────────────────────
# Other settings
# ─────────────────────────────────────────
CORS_ORIGIN=*
